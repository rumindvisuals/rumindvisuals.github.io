---
import Background from "../components/Background.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
const pageTitle = "RumindVisuals | Home";
---

<BaseLayout pageTitle={pageTitle}>
    <main>
        <section id="hero">
            <div class="image-container">
                <img src="/hero.png" alt="Rumind Visuals" class="hero-image" />
            </div>
            <div class="text-container">
                <div class="intro-titles">
                    <h2 class="intro-name">Erik Ramirez</h2>
                    <h2 class="intro-username">@RumindVisuals</h2>
                </div>
                <ul class="intro-skills">
                    <li class="skill">
                        <a href="#software-developer" class="skill-link"
                            >Software Developer</a
                        >
                    </li>
                    <li class="skill">
                        <a href="#data-analyst" class="skill-link"
                            >Data Analyst</a
                        >
                    </li>
                    <li class="skill">
                        <a href="#advertising-specialist" class="skill-link"
                            >Advertising Specialist</a
                        >
                    </li>
                    <li class="skill">
                        <a href="#photographer" class="skill-link"
                            >Photographer</a
                        >
                    </li>
                </ul>
            </div>
            <Background />
        </section>
    </main>
</BaseLayout>

<style is:global>
    footer {
        display: none;
    }
</style>

<style>
    main {
        display: flex;
        justify-content: center;
        align-items: center;
        width: 100vw;
        min-height: 100vh;
        padding: 0;
        margin: 0;
        box-sizing: border-box;
    }

    #hero {
        width: 100%;
        height: 100dvh;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        padding: 2rem 1rem;
        padding-bottom: 4rem;
        gap: 2rem;
        box-sizing: border-box;
        overflow: hidden;
    }

    .image-container {
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .hero-image {
        min-width: 180px;
        min-height: 180px;
        width: 100%;
        height: 100%;
        max-width: 320px;
        max-height: 320px;
        border-radius: 50%;
        box-shadow: 0 0 30px var(--accent-color);
        background-color: white;
        aspect-ratio: 1 / 1;
        object-fit: cover;
        margin: 0 auto;
        display: block;
        user-select: none;
        -webkit-user-drag: none;
        -webkit-user-select: none;
        pointer-events: none;
    }

    .text-container {
        width: 100%;
        max-width: 400px;
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        padding: 1rem 0;
        gap: 1.2rem;
        margin: 0 auto;
    }

    .intro-titles {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
    }

    .intro-name {
        font-size: 1.5rem;
        font-weight: bold;
        color: var(--accent-color);
        margin: 0;
        padding: 0;
        text-align: center;
    }

    .intro-username {
        font-size: 1rem;
        color: var(--text-color);
        margin: 0;
        padding: 0;
        text-align: center;
    }

    .intro-skills {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.8rem;
    }

    .skill {
        background-color: var(--background-color);
        border: 2px solid var(--accent-color);
        box-shadow: 0 0 10px var(--accent-color);
        border-radius: 20px;
        padding: 0.2rem 0.4rem;
        transition:
            background-color 0.3s,
            color 0.3s;
    }

    .skill:hover {
        background-color: var(--accent-color);
        color: var(--background-color);
    }

    .skill-link {
        font-size: 0.9rem;
        font-weight: 500;
        color: var(--accent-color);
        text-decoration: none;
        transition: color 0.3s;
        padding: 0.2rem 0.4rem;
        box-sizing: border-box;
    }

    .skill-link:hover {
        color: var(--background-color);
    }
</style>
